# ============================================================
# NetTriage AI — Environment Variables
# ============================================================
# Copy this file to .env and adjust values for your environment.
# NEVER commit the real .env file to version control.

# ---- Application ----
APP_NAME=NetTriage AI
ENVIRONMENT=dev

# ---- DeepSeek LLM ----
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=30
DEEPSEEK_MAX_RETRIES=2

# ---- Database ----
DATABASE_URL=sqlite:///./data/nettriage.db

# ---- File storage (relative to workspace root) ----
UPLOAD_DIR=./data/uploads
EXPORT_DIR=./data/exports
MAX_UPLOAD_MB=20
MAX_CSV_ROWS=50000
CSV_CHUNKSIZE=500

# ---- Review / confidence thresholds ----
REVIEW_CONFIDENCE_THRESHOLD=0.80
CONFLICT_SCORE_DELTA=0.08

# ---- Logging ----
LOG_LEVEL=INFO
